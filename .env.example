# Copy this file to `.env` and adjust the paths to point at whatever
# disk you want the ~10–15 GB of model weights to live on. The default
# below puts them next to the bench repo; change it if your dev drive
# is mounted elsewhere.
HF_HOME=./model-cache/hf
HUGGINGFACE_HUB_CACHE=./model-cache/hf/hub
TRANSFORMERS_CACHE=./model-cache/hf/transformers
NEMO_CACHE_DIR=./model-cache/nemo
TORCH_HOME=./model-cache/torch

# NeMo's logging is very chatty during inference; bump it up if you
# want to see what's happening.
NEMO_LOGGING_LEVEL=WARNING

# PyTorch on Apple Silicon: allow MPS fallback for any op not yet
# implemented on Metal (otherwise some NeMo ops refuse to load).
PYTORCH_ENABLE_MPS_FALLBACK=1
